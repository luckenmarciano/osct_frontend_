# Supabase PostgreSQL (get from Supabase project settings > Database > Connection string)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# JWT
JWT_ACCESS_SECRET="replace-with-random-64-char-string"
JWT_REFRESH_SECRET="replace-with-another-random-64-char-string"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"
JWT_QR_SECRET="replace-with-qr-specific-secret"

# Google Gemini (gratis — https://aistudio.google.com/apikey)
GEMINI_API_KEY=""

# Anthropic Claude (opsional)
ANTHROPIC_API_KEY=""

# Supabase (for Storage)
SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# Resend (email)
RESEND_API_KEY="re_..."
EMAIL_FROM="OSCT Platform <noreply@yourdomain.com>"

# App
PORT=4000
CLIENT_URL="http://localhost:5173"
NODE_ENV="development"
